# LLM Agent 配置
# 复制此文件为 .env 并填入实际的API密钥

# OpenAI API配置 (必需)
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4o

# Agent 行为参数
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=2000

# Agent 开关控制
AGENT_ENABLED=false
AGENT_DECISION_INTERVAL=300
AGENT_MAX_DECISIONS_PER_RUN=5

# 风控配置
AGENT_MAX_POSITION_PER_STOCK=0.15
AGENT_MIN_CONFIDENCE_THRESHOLD=0.7
